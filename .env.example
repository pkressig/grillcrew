# GrillCrew FCTC – Umgebungsvariablen (Beispiel)
# Kopieren nach .env und Werte anpassen. Niemals echte Geheimnisse committen.

# --- Datenbank ---
POSTGRES_DB=grillcrew
POSTGRES_USER=grillcrew
POSTGRES_PASSWORD=grillcrew_dev_only

# Vom Backend verwendet. Innerhalb von Docker Compose wird der Host "db" gesetzt.
# Für lokale Läufe ausserhalb von Docker:
DATABASE_URL=postgresql+psycopg://grillcrew:grillcrew_dev_only@localhost:5432/grillcrew

# --- Backend ---
APP_ENV=development           # development | test | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text               # text | json
BUSINESS_TIMEZONE=Europe/Zurich
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Authentifizierung (F002, D-037–D-040) ---
# Niemals den Entwicklungs-Default in Test/Produktion verwenden.
JWT_SECRET_KEY=dev-only-insecure-jwt-secret-change-me-in-every-real-environment
EMAIL_FROM_ADDRESS=no-reply@example.invalid
# SMTP_HOST leer lassen fuer lokale Entwicklung/Tests (nutzt den In-Memory-EmailSender).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FRONTEND_PUBLIC_URL=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
